{
  "$schema": "https://app.kilo.ai/config.json",
  "default_agent": "code",
  "instructions": ["AGENTS.md"],
  "snapshot": true,
  "share": "manual",
  "autoupdate": "notify",
  "compaction": {
    "auto": true,
    "prune": true
  },
  "lsp": true,
  "formatter": true,
  "mcp": {
    "shadcn": {
      "type": "local",
      "command": ["npx", "shadcn@latest", "mcp"],
      "enabled": true
    }
  }
}
